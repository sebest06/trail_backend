{
  "name": "appradar-backend",
  "version": "1.0.0",
  "description": "Backend for AppRadar",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "test": "jest --runInBand --verbose",
    "test:api": "cucumber-js"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "forceExit": true,
    "setupFiles": [
      "<rootDir>/tests/jest.setup.js"
    ]
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "socket.io": "^4.8.3",
    "uuid": "^9.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^11.2.0",
    "chai": "^4.5.0",
    "jest": "^30.4.2",
    "supertest": "^7.2.2"
  }
}
